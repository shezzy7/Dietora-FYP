# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB Atlas ────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/dietora?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# ─── Admin Seed ───────────────────────────────────────────
ADMIN_EMAIL=admin@dietora.pk
ADMIN_PASSWORD=Admin@12345

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# ─── Google OAuth ─────────────────────────────────────────
# 1. https://console.cloud.google.com → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID (type: Web application)
# 3. Authorized JS origins: http://localhost:5173
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here.apps.googleusercontent.com

# ─── AI Provider: Groq ────────────────────────────────────
# Free tier — get your key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Web Search: Tavily ───────────────────────────────────
# 1000 free searches/month — get your key at: https://app.tavily.com
# Used by chatbot for: WHO health guidance, real-time PK food prices, general web search
TAVILY_API_KEY=tvly-your_tavily_api_key_here

# ─── Google Places (REQUIRED for chatbot store search) ────
# Enable: Places API (New) at https://console.cloud.google.com
# Without this key, "where to buy" queries will not work
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# ─── Gemini (used ONLY by priceUpdater for meal-plan prices) ─
# Get key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ─── Frontend Origin ──────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
