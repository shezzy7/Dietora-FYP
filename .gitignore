# ═══════════════════════════════════════════════════════════════
#  DIETORA — Root .gitignore
#  Covers: Backend (Node.js) + Frontend (React/Vite)
# ═══════════════════════════════════════════════════════════════

# ─── SECRETS & ENVIRONMENT FILES ──────────────────────────────
# NEVER commit these — they contain API keys, DB passwords, JWT secrets
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging

# ─── NODE MODULES ─────────────────────────────────────────────
# Regenerated with: npm install
node_modules/
**/node_modules/

# ─── BUILD OUTPUTS ────────────────────────────────────────────
dist/
build/
out/
.output/
**/dist/
**/build/

# ─── VITE CACHE (Frontend) ────────────────────────────────────
.vite/
**/.vite/

# ─── LOGS ─────────────────────────────────────────────────────
*.log
*.log.*
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── DEPENDENCY LOCK (keep package-lock.json, ignore yarn.lock) 
yarn.lock
pnpm-lock.yaml
.pnp
.pnp.js

# ─── OS & EDITOR FILES ────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V8
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── TESTING & COVERAGE ───────────────────────────────────────
coverage/
.nyc_output/
*.lcov
.coverage

# ─── TYPESCRIPT ───────────────────────────────────────────────
*.tsbuildinfo

# ─── OPTIONAL / MISC ──────────────────────────────────────────
*.pem
*.key
*.cert
*.p12
*.pfx
*.backup
*.bak
*.tmp
*.temp
